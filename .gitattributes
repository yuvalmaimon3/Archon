# Git LFS tracking for large Unity binary assets.
#
# SETUP INSTRUCTIONS:
#   1. Install Git LFS: https://git-lfs.github.com/
#   2. Run in this repo: git lfs install
#   3. Uncomment the filter=lfs lines below (or run: git lfs track "*.png" etc.)
#
# The binary/-text flags below are always safe — they prevent line-ending corruption
# on binary files regardless of whether LFS is enabled.

# Textures & Images
*.psd -text
*.tga -text
*.png -text
*.jpg -text
*.jpeg -text
*.exr -text
*.hdr -text
*.tif -text
*.tiff -text

# 3D Models
*.fbx -text
*.FBX -text
*.obj -text
*.dae -text
*.blend -text

# Audio
*.wav -text
*.mp3 -text
*.ogg -text
*.aif -text
*.aiff -text
*.flac -text

# Video
*.mp4 -text
*.mov -text
*.avi -text
*.wmv -text
*.mkv -text
*.webm -text

# Fonts
*.ttf -text
*.otf -text

